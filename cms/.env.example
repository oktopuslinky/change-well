# ============================================================
# Change-Well CMS — environment template
# Copy to `.env` and fill in. NOTHING here is hardcoded in code,
# so you can deploy by setting these values when the company is ready.
# ============================================================

# --- REQUIRED ---
# Long random string used to sign auth tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Public URL where this admin app is served (used for cookies, links, CSRF).
# Local dev default is http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# --- DATABASE ---
# adapter: "sqlite" (default, zero-setup, great for the pitch/local) or "postgres" (production)
DATABASE_ADAPTER=sqlite
# sqlite: a file path URI. postgres: a full connection string.
DATABASE_URI=file:./change-well.db
# Example production Postgres:
# DATABASE_ADAPTER=postgres
# DATABASE_URI=postgres://user:password@host:5432/changewell?sslmode=require

# --- PUBLIC SITE (for CORS / CSRF allow-listing) ---
# Origin(s) of the public marketing site that may talk to this API.
# Comma-separated. Leave the localhost defaults for development.
PUBLIC_SITE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_ORIGINS=http://localhost:3000,http://localhost:3001

# --- MEDIA STORAGE ---
# If ALL S3_* vars are set, uploads go to S3 (production). Otherwise they are
# stored on local disk (./media) — fine for local/pitch use.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom endpoint for S3-compatible providers (R2, MinIO, etc.)
S3_ENDPOINT=

# --- CONTACT FORM (public site → destination) ---
# Where contact-form submissions should be delivered once known.
# Left blank for now; set at deploy time.
CONTACT_FORM_TO_EMAIL=

# --- OPTIONAL: seed an initial admin user on first `npm run seed` ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
